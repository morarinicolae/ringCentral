// Prisma schema for the private SMS/Call router.
//
// SWITCHING TO POSTGRESQL:
//   1. Change `provider` below from "sqlite" to "postgresql".
//   2. Set DATABASE_URL to your Postgres URL.
//   3. Run `npx prisma db push` (or `npx prisma migrate dev --name init`).
//
// No Prisma enums / native arrays, so the same models work on SQLite + Postgres.
//
// SEGMENTATION: a "Line" is one company phone number + its own team of sellers +
// its own round-robin cursor. Inbound SMS/calls to a line's number are
// distributed only among that line's sellers. A Contact is scoped to a line
// (same phone on two different company numbers = two separate contacts), so
// "one client -> one seller" holds within a line.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Line {
  id         String   @id @default(cuid())
  // The company phone number clients text/call (E.164). Unique per line.
  phoneE164  String   @unique @map("phone_e164")
  name       String
  isActive   Boolean  @default(true) @map("is_active")

  // Per-line RingCentral account. Each number can live on its OWN RingCentral
  // account (its own app credentials + JWT). When these are null the line uses
  // the global RINGCENTRAL_* env account. rcFromNumber defaults to phoneE164.
  // Secrets live in the local DB (single-tenant tool on the owner's VPS).
  rcClientId     String?  @map("rc_client_id")
  rcClientSecret String?  @map("rc_client_secret")
  rcJwt          String?  @map("rc_jwt")
  rcServerUrl    String?  @map("rc_server_url")
  rcUseA2p       Boolean? @map("rc_use_a2p")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  sellers        Seller[]
  sellerLines    SellerLine[]
  contacts       Contact[]
  conversations  Conversation[]
  messages       Message[]
  calls          Call[]
  routingStates  RoutingState[]

  @@map("lines")
}

model Seller {
  id                     String    @id @default(cuid())
  name                   String
  // Which line/team this seller belongs to (null = unassigned).
  lineId                 String?   @map("line_id")
  telegramUserId         String?   @unique @map("telegram_user_id")
  // The seller's own phone (E.164) — where a LIVE inbound call is forwarded to.
  phoneE164              String?   @map("phone_e164")
  ringcentralExtensionId String?   @map("ringcentral_extension_id")
  isActive               Boolean   @default(true) @map("is_active")
  priority               Int       @default(100)
  lastAssignedAt         DateTime? @map("last_assigned_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  line          Line?          @relation(fields: [lineId], references: [id])
  sellerLines   SellerLine[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  calls         Call[]

  @@index([lineId, isActive, priority, id])
  @@map("sellers")
}

// Which lines (company numbers) a seller serves, and — when the seller's
// Telegram target is a FORUM GROUP — which topic (message_thread_id) inbound
// from that line lands in. Lets one seller receive from multiple numbers, each
// number sorted into its own topic inside the seller's group.
//   Seller.telegramUserId = the group chat id (e.g. -1004324324)
//   SellerLine.telegramTopicId = the topic for THIS line inside that group
model SellerLine {
  id              String   @id @default(cuid())
  sellerId        String   @map("seller_id")
  lineId          String   @map("line_id")
  // Telegram forum topic (message_thread_id). Null = post to the group's
  // General thread / a plain (non-forum) chat.
  telegramTopicId String?  @map("telegram_topic_id")
  priority        Int      @default(100)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  line   Line   @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([sellerId, lineId])
  @@index([lineId, isActive, priority, id])
  @@map("seller_lines")
}

model Contact {
  id               String    @id @default(cuid())
  phoneE164        String    @map("phone_e164")
  lineId           String    @map("line_id")
  assignedSellerId String?   @map("assigned_seller_id")
  // The client's own forum TOPIC (message_thread_id) inside the owner seller's
  // Telegram group — every SMS/call notification for this client lands there.
  telegramTopicId  String?   @map("telegram_topic_id")
  // status: active | closed | blocked | opt_out
  status           String    @default("active")
  firstMessageAt   DateTime? @map("first_message_at")
  lastMessageAt    DateTime? @map("last_message_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  line           Line           @relation(fields: [lineId], references: [id])
  assignedSeller Seller?        @relation(fields: [assignedSellerId], references: [id])
  conversations  Conversation[]
  messages       Message[]
  calls          Call[]

  // Same phone can exist once per line.
  @@unique([phoneE164, lineId])
  @@index([assignedSellerId])
  @@map("contacts")
}

model Conversation {
  id               String    @id @default(cuid())
  contactId        String    @map("contact_id")
  lineId           String    @map("line_id")
  assignedSellerId String?   @map("assigned_seller_id")
  // status: open | closed | blocked
  status           String    @default("open")
  lastMessageAt    DateTime? @map("last_message_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  contact  Contact   @relation(fields: [contactId], references: [id])
  line     Line      @relation(fields: [lineId], references: [id])
  seller   Seller?   @relation(fields: [assignedSellerId], references: [id])
  messages Message[]

  @@index([contactId])
  @@index([assignedSellerId])
  @@map("conversations")
}

model Message {
  id                   String   @id @default(cuid())
  conversationId       String   @map("conversation_id")
  contactId            String   @map("contact_id")
  lineId               String?  @map("line_id")
  sellerId             String?  @map("seller_id")
  // direction: inbound | outbound
  direction            String
  body                 String
  ringcentralMessageId String?  @unique @map("ringcentral_message_id")
  telegramMessageId    String?  @map("telegram_message_id")
  telegramChatId       String?  @map("telegram_chat_id")
  // status: received | forwarded_to_seller | pending_send | sent | test_sent | failed | duplicate | blocked
  status               String
  failureReason        String?  @map("failure_reason")
  rawPayloadJson       String?  @map("raw_payload_json")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  contact      Contact      @relation(fields: [contactId], references: [id])
  line         Line?        @relation(fields: [lineId], references: [id])
  seller       Seller?      @relation(fields: [sellerId], references: [id])

  @@index([conversationId])
  @@index([contactId])
  @@index([telegramChatId, telegramMessageId])
  @@map("messages")
}

model Call {
  id                String    @id @default(cuid())
  lineId            String    @map("line_id")
  contactId         String    @map("contact_id")
  sellerId          String?   @map("seller_id")
  // direction: inbound | outbound
  direction         String    @default("inbound")
  // result: answered | missed | voicemail | rejected | busy | unknown
  result            String    @default("unknown")
  durationSec       Int?      @map("duration_sec")
  ringcentralCallId String?   @unique @map("ringcentral_call_id")
  telegramMessageId String?   @map("telegram_message_id")
  telegramChatId    String?   @map("telegram_chat_id")
  startedAt         DateTime? @map("started_at")
  rawPayloadJson    String?   @map("raw_payload_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  line    Line     @relation(fields: [lineId], references: [id])
  contact Contact  @relation(fields: [contactId], references: [id])
  seller  Seller?  @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([contactId])
  @@index([lineId, startedAt])
  @@map("calls")
}

model RoutingState {
  id           String   @id @default(cuid())
  // One cursor per line (null = legacy/global).
  lineId       String?  @unique @map("line_id")
  mode         String   @default("round_robin")
  lastSellerId String?  @map("last_seller_id")
  updatedAt    DateTime @updatedAt @map("updated_at")

  line Line? @relation(fields: [lineId], references: [id])

  @@map("routing_state")
}

model WebhookEvent {
  id              String    @id @default(cuid())
  // provider: ringcentral | telegram
  provider        String
  externalEventId String?   @map("external_event_id")
  eventHash       String    @unique @map("event_hash")
  // status: received | processed | duplicate | failed
  status          String    @default("received")
  rawPayloadJson  String    @map("raw_payload_json")
  errorMessage    String?   @map("error_message")
  createdAt       DateTime  @default(now()) @map("created_at")
  processedAt     DateTime? @map("processed_at")

  @@map("webhook_events")
}

model AuditLog {
  id          String   @id @default(cuid())
  // actor_type: system | seller | admin
  actorType   String   @map("actor_type")
  actorId     String?  @map("actor_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  detailsJson String?  @map("details_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("audit_logs")
}
