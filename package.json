{
  "name": "sms-router",
  "version": "1.0.0",
  "private": true,
  "description": "Private SMS distribution router: RingCentral SMS <-> Telegram, round-robin per-seller ownership. Not a CRM.",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "set-telegram-webhook": "tsx scripts/set-telegram-webhook.ts",
    "rc:test": "tsx scripts/ringcentral-test.ts",
    "rc:subscribe": "tsx scripts/ringcentral-subscribe.ts",
    "pretest": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "rc:send": "tsx scripts/ringcentral-send.ts",
    "rc:poll-inbound": "tsx scripts/ringcentral-poll-inbound.ts",
    "rc:poll-a2p": "tsx scripts/ringcentral-poll-a2p.ts",
    "dev:poll": "tsx watch scripts/dev-poll.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
