# ---- Runtime ----
NODE_ENV=development
PORT=3000
# Public HTTPS base URL of this service (used to register the Telegram + RingCentral webhooks)
APP_BASE_URL=https://your-app.example.com
# Domain Caddy issues HTTPS for on deploy (docker-compose). Usually == APP_BASE_URL host.
APP_DOMAIN=router.yourcompany.com

# ---- Database ----
# Local / testing (SQLite). For PostgreSQL: set the provider in
# prisma/schema.prisma to "postgresql" and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/sms_router?schema=public"

# ---- Test mode (SAFETY) ----
# TEST_MODE=true means NO real SMS is sent unless ALLOW_REAL_SMS=true as well.
# In TEST_MODE the outbound SMS payload is logged and marked test_sent;
# Telegram notifications are still delivered.
TEST_MODE=true
ALLOW_REAL_SMS=false

# ---- RingCentral ----
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_USERNAME=
RINGCENTRAL_EXTENSION=
RINGCENTRAL_PASSWORD=
RINGCENTRAL_FROM_NUMBER=+15550009999
# Optional: JWT bearer credential (preferred by RingCentral over password grant).
# If set, it is used instead of USERNAME/PASSWORD.
RINGCENTRAL_JWT=
# Set true for TCR/10DLC (A2P High Volume SMS) accounts: send + inbound go
# through the /a2p-sms API instead of the classic per-extension /sms endpoint.
RINGCENTRAL_USE_A2P=false
# NOTE: the vars above are the DEFAULT (global) RingCentral account. Each line
# (company number) can instead have its OWN account — set its client id / secret
# / JWT / server / A2P per line in the /panel ("Cont RingCentral per număr").
# The poller then polls every distinct account and replies go from each number's
# own account. Lines without their own creds fall back to this global account.

# ---- Deploy without a public webhook URL ----
# true = the server also polls Telegram + A2P inbound in-process (single process,
# no public URL needed). Access the panel via SSH tunnel.
POLL_MODE=false

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
# Optional shared secret Telegram echoes in X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated Telegram user IDs treated as admins (can see everything).
ADMIN_TELEGRAM_IDS=

# ---- Admin HTTP auth ----
# Shared token required in the X-Admin-Token header for /admin endpoints.
ADMIN_API_TOKEN=change-me-admin-token

# ---- Seed / provisioning (npx prisma db seed) ----
# Company numbers (lines). LINE1 defaults to RINGCENTRAL_FROM_NUMBER.
#   LINE1_NUMBER / LINE1_NAME, LINE2_NUMBER / LINE2_NAME, ...
# Sellers (n = 1..3). SELLERn_TELEGRAM_ID is the seller's Telegram TARGET:
#   - a 1:1 chat id (their user id) for a private setup, OR
#   - a GROUP id (negative, e.g. -1004247328406) for the "one group per team,
#     one topic per number" setup. Bot must be an admin of that group.
#   SELLERn_NAME, SELLERn_TELEGRAM_ID, and optionally SELLERn_TOPIC = the forum
#   topic (message_thread_id) inbound on that seller's line lands in.
# Multiple numbers per seller / more topics: configure in the /panel UI
# (section "Vânzători" → "Pune pe număr / setează topic") — it writes seller_lines.
# SELLER1_NAME=Ana
# SELLER1_TELEGRAM_ID=-1004247328406
# SELLER1_TOPIC=
# SELLER2_NAME=Bogdan
# SELLER2_TELEGRAM_ID=-1004448877126
# SELLER2_TOPIC=

# ---- Outbound SMS retry policy (temporary errors only) ----
SMS_MAX_RETRIES=3
SMS_RETRY_BASE_MS=500
