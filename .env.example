# ---- Runtime ----
NODE_ENV=development
PORT=3000
# Public HTTPS base URL of this service (used to register the Telegram + RingCentral webhooks)
APP_BASE_URL=https://your-app.example.com
# Domain Caddy issues HTTPS for on deploy (docker-compose). Usually == APP_BASE_URL host.
APP_DOMAIN=router.yourcompany.com

# ---- Database ----
# Local / testing (SQLite). For PostgreSQL: set the provider in
# prisma/schema.prisma to "postgresql" and use a postgres:// URL here.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/sms_router?schema=public"

# ---- Test mode (SAFETY) ----
# TEST_MODE=true means NO real SMS is sent unless ALLOW_REAL_SMS=true as well.
# In TEST_MODE the outbound SMS payload is logged and marked test_sent;
# Telegram notifications are still delivered.
TEST_MODE=true
ALLOW_REAL_SMS=false

# ---- RingCentral ----
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_USERNAME=
RINGCENTRAL_EXTENSION=
RINGCENTRAL_PASSWORD=
RINGCENTRAL_FROM_NUMBER=+15550009999
# Optional: JWT bearer credential (preferred by RingCentral over password grant).
# If set, it is used instead of USERNAME/PASSWORD.
RINGCENTRAL_JWT=
# Set true for TCR/10DLC (A2P High Volume SMS) accounts: send + inbound go
# through the /a2p-sms API instead of the classic per-extension /sms endpoint.
RINGCENTRAL_USE_A2P=false

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
# Optional shared secret Telegram echoes in X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated Telegram user IDs treated as admins (can see everything).
ADMIN_TELEGRAM_IDS=

# ---- Admin HTTP auth ----
# Shared token required in the X-Admin-Token header for /admin endpoints.
ADMIN_API_TOKEN=change-me-admin-token

# ---- Outbound SMS retry policy (temporary errors only) ----
SMS_MAX_RETRIES=3
SMS_RETRY_BASE_MS=500
